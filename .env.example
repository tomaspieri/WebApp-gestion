# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Encriptación ───────────────────────────────────────────────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── URL de la app (sin barra final) ───────────────────────────────────────────
APP_URL=https://chana-gestion.vercel.app

# ── Origen permitido (tienda web) ─────────────────────────────────────────────
ALLOWED_ORIGIN=https://chanaindumentaria.vercel.app

# ── MercadoPago OAuth ─────────────────────────────────────────────────────────
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=https://chana-gestion.vercel.app/api/mp/callback

# ── Brevo SMTP (clave de aplicación) ──────────────────────────────────────────
# Obtener en: https://app.brevo.com → SMTP & API → SMTP
BREVO_SMTP_PASS=

# ── Telegram (opcional — notificaciones de cuotas) ────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Cron jobs (Vercel genera el secret automáticamente en Pro, o definilo vos) ─
CRON_SECRET=

# ── Correo Argentino (opcional — cotizador de envíos) ─────────────────────────
CORREO_ARG_USER=
CORREO_ARG_PASS=
# CORREO_ARG_ENV=prod
